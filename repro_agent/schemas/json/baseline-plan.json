{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reproagent.dev/schemas/baseline-plan-0.2.0.json",
  "type": "object",
  "required": [
    "metadata",
    "mode",
    "status",
    "target",
    "repository",
    "audit_id",
    "command",
    "supplied_dataset",
    "blockers",
    "options",
    "assumptions",
    "next_steps"
  ],
  "properties": {
    "metadata": {"$ref": "common.json#/$defs/metadata"},
    "mode": {
      "enum": ["exact_reproduction", "independent_replication", "fair_benchmark"]
    },
    "status": {"type": "string"},
    "target": {"type": "object"},
    "repository": {"type": "object"},
    "audit_id": {"type": "string"},
    "command": {"type": "array", "items": {"type": "string"}},
    "supplied_dataset": {"type": ["string", "null"]},
    "blockers": {"type": "array"},
    "options": {"type": "array"},
    "assumptions": {"type": "array"},
    "next_steps": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
